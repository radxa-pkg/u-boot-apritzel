From 41caf3363a58b8f8d0e76777d858be269db612e9 Mon Sep 17 00:00:00 2001
From: Feng Zhang <feng@radxa.com>
Date: Mon, 2 Mar 2026 11:04:09 +0000
Subject: [PATCH 13/14] include: sunxi_gpio: Add two extra GPIO bank
 definitions

Signed-off-by: Feng Zhang <feng@radxa.com>
---
 include/sunxi_gpio.h | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/src/include/sunxi_gpio.h b/src/include/sunxi_gpio.h
index ba8e5428900..222b961622c 100644
--- a/src/include/sunxi_gpio.h
+++ b/src/include/sunxi_gpio.h
@@ -49,6 +49,9 @@
 #define SUNXI_GPIO_G	6
 #define SUNXI_GPIO_H	7
 #define SUNXI_GPIO_I	8
+/* sun60i has two extra banks of GPIO */
+#define SUNXI_GPIO_J	9
+#define SUNXI_GPIO_K	10
 
 /*
  * sun6i/sun8i and later SoCs have an additional GPIO controller (R_PIO)
@@ -85,6 +88,8 @@ enum sunxi_gpio_number {
 	SUNXI_GPIO_G_START = SUNXI_GPIO_NEXT(SUNXI_GPIO_F),
 	SUNXI_GPIO_H_START = SUNXI_GPIO_NEXT(SUNXI_GPIO_G),
 	SUNXI_GPIO_I_START = SUNXI_GPIO_NEXT(SUNXI_GPIO_H),
+	SUNXI_GPIO_J_START = SUNXI_GPIO_NEXT(SUNXI_GPIO_I),
+	SUNXI_GPIO_K_START = SUNXI_GPIO_NEXT(SUNXI_GPIO_J),
 	SUNXI_GPIO_L_START = 352,
 	SUNXI_GPIO_M_START = SUNXI_GPIO_NEXT(SUNXI_GPIO_L),
 	SUNXI_GPIO_N_START = SUNXI_GPIO_NEXT(SUNXI_GPIO_M),
@@ -100,6 +105,8 @@ enum sunxi_gpio_number {
 #define SUNXI_GPG(_nr)	(SUNXI_GPIO_G_START + (_nr))
 #define SUNXI_GPH(_nr)	(SUNXI_GPIO_H_START + (_nr))
 #define SUNXI_GPI(_nr)	(SUNXI_GPIO_I_START + (_nr))
+#define SUNXI_GPJ(_nr)	(SUNXI_GPIO_J_START + (_nr))
+#define SUNXI_GPK(_nr)	(SUNXI_GPIO_K_START + (_nr))
 #define SUNXI_GPL(_nr)	(SUNXI_GPIO_L_START + (_nr))
 #define SUNXI_GPM(_nr)	(SUNXI_GPIO_M_START + (_nr))
 #define SUNXI_GPN(_nr)	(SUNXI_GPIO_N_START + (_nr))
-- 
