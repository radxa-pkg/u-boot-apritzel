From 1d667123d37a7835692b44eac684abcad78dfff6 Mon Sep 17 00:00:00 2001
From: Feng Zhang <feng@radxa.com>
Date: Wed, 4 Mar 2026 09:42:30 +0000
Subject: [PATCH 1/2] arm: dts: cubie-a7s: Keep board ID detect power enabled

Signed-off-by: Feng Zhang <feng@radxa.com>
---
 arch/arm/dts/sun60i-a733-cubie-a7s.dts | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/src/arch/arm/dts/sun60i-a733-cubie-a7s.dts b/src/arch/arm/dts/sun60i-a733-cubie-a7s.dts
index 438a0defcf1..f5e162a6170 100644
--- a/src/arch/arm/dts/sun60i-a733-cubie-a7s.dts
+++ b/src/arch/arm/dts/sun60i-a733-cubie-a7s.dts
@@ -187,6 +187,14 @@
 				regulator-name = "vdd-cpul";
 			};
 
+			/* For Board ID detection */
+			reg_bldo1: bldo1 {
+				regulator-always-on;
+				regulator-min-microvolt = <800000>;
+				regulator-max-microvolt = <1000000>;
+				regulator-name = "vcc-pk";
+			};
+
 			reg_cldo1: cldo1 {
 				regulator-min-microvolt = <1800000>;
 				regulator-max-microvolt = <1800000>;
-- 
2.49.0

