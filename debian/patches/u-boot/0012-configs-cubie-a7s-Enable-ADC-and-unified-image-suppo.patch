From 49e83c8157d83ac8f7c05cecb4eb616796acb00f Mon Sep 17 00:00:00 2001
From: Feng Zhang <feng@radxa.com>
Date: Mon, 2 Mar 2026 06:29:34 +0000
Subject: [PATCH 3/3] configs: cubie-a7s: Enable ADC and unified image support

Signed-off-by: Feng Zhang <feng@radxa.com>
---
 configs/radxa-cubie-a7s_defconfig | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/src/configs/radxa-cubie-a7s_defconfig b/src/configs/radxa-cubie-a7s_defconfig
index e15af095202..cf8e8f6d756 100644
--- a/src/configs/radxa-cubie-a7s_defconfig
+++ b/src/configs/radxa-cubie-a7s_defconfig
@@ -7,6 +7,7 @@ CONFIG_SPL=y
 CONFIG_MACH_SUN60I_A733=y
 CONFIG_MMC_SUNXI_SLOT_EXTRA=2
 # CONFIG_VIDEO_SUNXI is not set
+CONFIG_RADXA_UNIFIED_IMAGE=y
 # CONFIG_SYS_MALLOC_CLEAR_ON_INIT is not set
 CONFIG_SPL_LOAD_FIT_ADDRESS=0x48200000
 CONFIG_BOOTDELAY=3
@@ -15,6 +16,8 @@ CONFIG_SPL_RAM_DEVICE=y
 CONFIG_CMD_DFU=y
 CONFIG_CMD_I2C=y
 CONFIG_NET_RANDOM_ETHADDR=y
+CONFIG_ADC=y
+CONFIG_SUNXI_GPADC=y
 CONFIG_SYS_I2C_MVTWSI=y
 CONFIG_MISC=y
 CONFIG_NVMEM=y
-- 
